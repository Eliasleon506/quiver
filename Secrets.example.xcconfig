// Copy this file to `Secrets.xcconfig` (which is git-ignored) and paste your
// own Google AI Studio Gemini key. Then rebuild.
//
//   cp Secrets.example.xcconfig Secrets.xcconfig
//   # edit Secrets.xcconfig, set GEMINI_API_KEY = ...
//
// Leaving it unset is fine — the app just runs on the rule engine.

GEMINI_API_KEY = your_gemini_key_here
